import "base"
import "production_translation"
import "season_translation"
import "genre_translation"
import "sub_genre_translation"

model Language extends Base {
  code                    String                  @unique() 
  name                    String?
  productionTranslations  ProductionTranslation[]
  seasonTranslations      SeasonTranslation[]
  genreTranslations       GenreTranslation[]
  subGenreTranslations    SubGenreTranslation[]
}