import "base"
import "title"
import "sub_genre"

model TitleSubGenre extends Base {
  title      Title    @relation(fields: [titleId], references: [id], onDelete: Cascade)
  titleId    String   @map("title_id")
  subGenre   SubGenre @relation(fields: [subGenreId], references: [id], onDelete: Cascade)
  subGenreId String   @map("subGenre_id")

  @@unique([titleId, subGenreId])
}